[Unit]
Description=COE dictation daemon
Documentation=https://github.com/missuo/koe
Wants=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/coe serve
Restart=on-failure
RestartSec=2
EnvironmentFile=-%h/.config/coe/env

[Install]
WantedBy=default.target
